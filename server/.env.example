# Server
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Database
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/nayepankh

# JWT
JWT_ACCESS_SECRET=replace_with_a_long_random_string
JWT_REFRESH_SECRET=replace_with_a_different_long_random_string
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Email (Gmail SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=contact@nayepankh.com
EMAIL_PASS=your_gmail_app_password
EMAIL_FROM="NayePankh Foundation <contact@nayepankh.com>"

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# App
SUPER_ADMIN_EMAIL=admin@nayepankh.com
SUPER_ADMIN_PASSWORD=ChangeMe123!
VOLUNTEER_MIN_AGE=14
CERTIFICATE_MIN_HOURS=20
CERTIFICATE_MIN_EVENTS=3
